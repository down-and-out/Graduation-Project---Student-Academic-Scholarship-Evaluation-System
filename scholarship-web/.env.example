# 环境变量配置示例
# 复制此文件为 .env、.env.development 或 .env.production

# ========== 安全配置 ==========

# RSA 公钥（用于密码加密）
# 格式：-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# 注意：需要使用\n表示换行
# 生产环境应使用独立的密钥对
VITE_RSA_PUBLIC_KEY=your_rsa_public_key_here

# ========== API 配置 ==========

# API 基础 URL
# 开发环境：/api（使用代理）
# 生产环境：完整 URL 如 https://api.yourdomain.com 或 /api（使用反向代理）
VITE_API_BASE_URL=/api

# ========== 应用配置 ==========

# 应用标题
VITE_APP_TITLE=研究生学业奖学金评定系统

# ========== 可选配置 ==========

# 是否启用 Mock 数据（开发环境）
# VITE_USE_MOCK=false

# 是否启用错误上报（生产环境）
# VITE_ENABLE_ERROR_REPORTING=false

# 日志级别：debug | info | warn | error
# VITE_LOG_LEVEL=debug