# 依赖
node_modules/
.pnp/
.pnp.js

# 构建输出
dist/
dist-ssr/
*.local

# 编辑器
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 环境变量（敏感信息）
# 注意：.env.development 和 .env.production 可提交到版本控制系统
# 但包含敏感信息的 .env.local 和个人本地配置不应提交
.env
.env.local
.env.*.local

# 日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 测试
coverage/
*.lcov
.nyc_output/

# 临时文件
*.tmp
*.temp
.DS_Store
Thumbs.db

# 密钥文件
*.pem
*.key
